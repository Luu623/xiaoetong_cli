{
  "name": "xiaoetong-cli",
  "version": "0.1.0",
  "description": "CLI tool for Xiaoetong study platform",
  "type": "module",
  "bin": {
    "xe": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outdir=dist --banner:js='#!/usr/bin/env node' && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "axios": "^1.8.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "sherpa-onnx-node": "^1.12.39"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "esbuild": "^0.25.0",
    "eslint": "^10.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.2"
  }
}
